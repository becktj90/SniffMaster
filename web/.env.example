# SniffMaster Web Dashboard — Environment Variables
# Copy this to .env.local for local dev, or set in Vercel dashboard for production.

# ⚠️  CRITICAL: Shared secret between ESP32 and the relay API.
# IMPORTANT: This key MUST also be set in firmware/include/web_dashboard_config.h
# Generate one: openssl rand -hex 16
# Then rebuild and flash the firmware with the new key.
SNIFFMASTER_API_KEY=change-me-to-a-random-secret

# Upstash Redis (free tier: https://upstash.com)
# Create a Redis database, then copy the REST credentials here.
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...your-token-here

# Optional: Enable weather briefing with AI-generated insights
# If not set, weather briefing uses deterministic local forecast
# OPENAI_API_KEY=sk-...

# Optional: Separate admin/owner key for dashboard management
# If not set, falls back to SNIFFMASTER_API_KEY for owner operations
# SNIFFMASTER_OWNER_KEY=...
