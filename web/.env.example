# SniffMaster Web Dashboard — Environment Variables
# Copy this to .env.local for local dev, or set in Vercel dashboard for production.

# Shared secret between ESP32 and the relay API.
# Generate one: openssl rand -hex 16
SNIFFMASTER_API_KEY=change-me-to-a-random-secret

# Upstash Redis (free tier: https://upstash.com)
# Create a Redis database, then copy the REST credentials here.
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...your-token-here
